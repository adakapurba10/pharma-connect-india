<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    
    <!-- Beautiful shadow/glow path -->
    <path
        android:fillColor="#15000000"
        android:pathData="M 32 32 H 76 V 76 H 32 Z" />

    <!-- Shield / Capsule background in the foreground layer -->
    <path
        android:pathData="M 54 20 C 68 20, 80 28, 80 48 C 80 68, 54 88, 54 88 C 54 88, 28 68, 28 48 C 28 28, 40 20, 54 20 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="54"
                android:startY="20"
                android:endX="54"
                android:endY="88">
                <item android:offset="0.0" android:color="#00D2C4" /> <!-- Neon Teal -->
                <item android:offset="1.0" android:color="#0D9488" /> <!-- Medical Teal -->
            </gradient>
        </aapt:attr>
    </path>

    <!-- White Medical Cross inside the Shield -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M 49 39 H 59 V 49 H 69 V 59 H 59 V 69 H 49 V 59 H 39 V 49 H 49 Z" />
        
</vector>
